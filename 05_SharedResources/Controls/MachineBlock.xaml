<UserControl x:Class="_99_SharedResources.Controls.MachineBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_99_SharedResources.Controls"
             xmlns:converters="clr-namespace:_99_SharedResources.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="Self">
    <UserControl.Resources>
        <converters:StatusToColor x:Key="StatusToColor"/>
        <converters:StatusToText x:Key="StatusToText"/>
    </UserControl.Resources>
    <Border Width="140"
            Height="140"
            Background="#2c3e50"
            CornerRadius="12"
            BorderBrush="#1a2632"
            BorderThickness="2">
        <!-- 外层立体阴影 -->
        <Border.Effect>
            <DropShadowEffect BlurRadius="10"
                              ShadowDepth="4"
                              Direction="315"
                              Opacity="0.5"
                              Color="#000000" />
        </Border.Effect>

        <Grid Margin="3">
            <!-- 主体凹陷区域（就像CPU中间的die） -->
            <Border Background="#34495e"
                    CornerRadius="8"
                    BorderBrush="#1a2632"
                    BorderThickness="1.5"
                    Margin="4">

                <!-- 内阴影（制造凹陷感） -->
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6"
                                      ShadowDepth="2"
                                      Direction="135"
                                      Opacity="0.4"
                                      Color="#000000" />
                </Border.Effect>

                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 顶部区域：设备编号 + 状态灯（像CPU上的文字） -->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,4,0,4">

                        <!-- 状态灯 -->
                        <Border Width="10"
                                Height="10"
                                CornerRadius="5"
                                Background="{Binding Device.Status,Converter={StaticResource StatusToColor},ElementName=Self}"
                                Margin="0,2,6,0">
                        </Border>

                        <TextBlock Text="{Binding Device.ID,ElementName=Self}"
                                   Foreground="#ecf0f1"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   FontFamily="Consolas" />
                    </StackPanel>

                    <!-- 中央区域：工件信息（像CPU型号标识） -->
                    <Border Grid.Row="1"
                            Background="#1a2632"
                            CornerRadius="6"
                            Padding="4"
                            Margin="0,4">
                        <StackPanel>
                            <TextBlock Text="{Binding Device.CurrentWorkpiece,ElementName=Self}"
                                       Foreground="#3498db"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       FontFamily="Consolas"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Device.Status,Converter={StaticResource StatusToText},ElementName=Self}"
                                       Foreground="#7f8c8d"
                                       FontSize="10"
                                       FontFamily="Consolas"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- 底部区域：进度条（像CPU的金手指） -->
                    <StackPanel Grid.Row="2"
                                Margin="0,4">
                        <TextBlock Text="{Binding Device.Status,ElementName=Self}"
                                   Foreground="#7f8c8d"
                                   FontSize="8"
                                   FontFamily="Consolas"
                                   Margin="0,0,0,2" />
                        <ProgressBar Value="{Binding Device.Progress,ElementName=Self}"
                                     Maximum="100"
                                     Height="8"
                                     Foreground="#3498db"
                                     Background="#1a2632"
                                     BorderThickness="0" />
                        <TextBlock Text="{Binding Device.Progress,StringFormat={}{0}%,ElementName=Self}"
                                   Foreground="#7f8c8d"
                                   FontSize="8"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Right"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
            <!-- 四个角的装饰小方块（像CPU的电容） -->
            <Grid>
                <Ellipse Width="6"
                         Height="6"
                         Fill="#f1c40f"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Margin="2,2,0,0" />
                <Ellipse Width="6"
                         Height="6"
                         Fill="#f1c40f"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Margin="0,2,2,0" />
                <Ellipse Width="6"
                         Height="6"
                         Fill="#f1c40f"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Bottom"
                         Margin="2,0,0,2" />
                <Ellipse Width="6"
                         Height="6"
                         Fill="#f1c40f"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Bottom"
                         Margin="0,0,2,2" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
