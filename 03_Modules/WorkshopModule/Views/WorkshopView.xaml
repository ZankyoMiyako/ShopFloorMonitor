<UserControl x:Class="_03_Modules.Views.WorkshopView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:_99_SharedResources.Controls;assembly=99_SharedResources"
             xmlns:converters="clr-namespace:_99_SharedResources.Converters;assembly=99_SharedResources"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:_03_Modules.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:ColumnToXConverter x:Key="ColumnToXConverter" />
        <converters:RowToYConverter x:Key="RowToYConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Viewbox>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Border Grid.RowSpan="2"
                        Margin="0,0,0,90"
                        Background="#34406b"
                        BorderBrush="#2939ab"
                        BorderThickness="1,1,1,1"
                        CornerRadius="15">
                    <Border.Effect>
                        <DropShadowEffect />
                    </Border.Effect>
                </Border>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Margin="15"
                               FontSize="25"
                               FontWeight="SemiBold"
                               Foreground="AliceBlue"
                               Text="车间" />
                    <Border Grid.Column="1"
                            Background="White"
                            Height="2"
                            VerticalAlignment="Center" />
                </Grid>
                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding Devices}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="400"
                                    Height="700" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:MachineBlock Device="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemContainerStyle>
                        <Style>
                            <Setter Property="Canvas.Left"
                                    Value="{Binding Column, Converter={StaticResource ColumnToXConverter}}" />
                            <Setter Property="Canvas.Top"
                                    Value="{Binding Row, Converter={StaticResource RowToYConverter}}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </Grid>
        </Viewbox>

        <Grid Grid.Column="1"
              Margin="20"
              Background="Azure">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="20"
                       Text="未定功能" />
        </Grid>
    </Grid>
</UserControl>
