<UserControl x:Class="_03_Modules.DebuggerModule.Views.TCPConnectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:_03_Modules.DebuggerModule.Views"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Border Background="AliceBlue" />
        <Grid HorizontalAlignment="Center"
              Margin="10,60">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,10">
                <TextBlock Text="IP地址:"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="10,0,30,0" />
                <TextBox Width="100" />
            </StackPanel>
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,10">
                <TextBlock Text="端口号:"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="10,0,30,0" />
                <TextBox Width="100" />
            </StackPanel>
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Margin="0,10">
                <TextBlock Text="超时时间:"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="10,0" />
                <TextBox Width="100" />
            </StackPanel>
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Margin="0,10">
                <TextBlock Text="重连次数:"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="10,0" />
                <TextBox Width="100" />
            </StackPanel>
            <DockPanel Grid.Row="4"
                       LastChildFill="False">
                <Button DockPanel.Dock="Left"
                        Content="取消"
                        Width="60"
                        Margin="10" />
                <Button DockPanel.Dock="Right"
                        Content="确认"
                        Width="60"
                        Margin="0,10" />
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
