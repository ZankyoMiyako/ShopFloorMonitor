<UserControl x:Class="_03_Modules.DebuggerModule.Views.RTUConnectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_03_Modules.DebuggerModule.Views"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border Background="AliceBlue" />
        <Grid HorizontalAlignment="Center"
              Margin="10,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,10">
                <TextBlock Text="串口号:"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="10,0,30,0" />
                <TextBox Width="100" />
            </StackPanel>
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,10">
                <TextBlock Text="波特率:"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="10,0,30,0" />
                <TextBox Width="100" />
            </StackPanel>
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Margin="0,10">
                <TextBlock Text="数据位:"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="10,0,30,0" />
                <TextBox Width="100" />
            </StackPanel>
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Margin="0,10">
                <TextBlock Text="停止位:"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="10,0,30,0" />
                <TextBox Width="100" />
            </StackPanel>
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        Margin="0,10">
                <TextBlock Text="校验位:"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="10,0,30,0" />
                <TextBox Width="100" />
            </StackPanel>
            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        Margin="0,10">
                <TextBlock Text="超时时间:"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="10,0" />
                <TextBox Width="100" />
            </StackPanel>
            <StackPanel Grid.Row="6"
                        Orientation="Horizontal"
                        Margin="0,10">
                <TextBlock Text="重连次数:"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="10,0" />
                <TextBox Width="100" />
            </StackPanel>
            <DockPanel Grid.Row="7"
                       LastChildFill="False">
                <Button DockPanel.Dock="Left"
                        Content="取消"
                        Width="60"
                        Margin="10"
                        Command="{Binding DrawerControl}"
                        CommandParameter="取消" />
                <Button DockPanel.Dock="Right"
                        Content="确认"
                        Width="60"
                        Margin="0,10"
                        Command="{Binding DrawerControl}"
                        CommandParameter="确定" />
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
