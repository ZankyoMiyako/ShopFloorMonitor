<UserControl x:Class="_03_Modules.DebuggerModule.Views.RTUConnectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:_03_Modules.DebuggerModule.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             d:DesignHeight="450"
             d:DesignWidth="800"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">
    <Grid>
        <Border Background="AliceBlue" />
        <Grid Margin="10,40" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0"
                        Margin="0,10"
                        Orientation="Horizontal">
                <TextBlock Margin="10,0,30,0"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Text="串口号:" />
                <ComboBox Width="100"
                          ItemsSource="{Binding RTUConnectOptions.ComPortOptions}"
                          SelectedItem="{Binding ConnectParams.ComPort}" />
            </StackPanel>
            <StackPanel Grid.Row="1"
                        Margin="0,10"
                        Orientation="Horizontal">
                <TextBlock Margin="10,0,30,0"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Text="波特率:" />
                <ComboBox Width="100"
                          ItemsSource="{Binding RTUConnectOptions.BaudRateOptions}"
                          SelectedItem="{Binding ConnectParams.BaudRate}" />
            </StackPanel>
            <StackPanel Grid.Row="2"
                        Margin="0,10"
                        Orientation="Horizontal">
                <TextBlock Margin="10,0,30,0"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Text="数据位:" />
                <ComboBox Width="100"
                          ItemsSource="{Binding RTUConnectOptions.DataBitOptions}"
                          SelectedItem="{Binding ConnectParams.DataBit}" />
            </StackPanel>
            <StackPanel Grid.Row="3"
                        Margin="0,10"
                        Orientation="Horizontal">
                <TextBlock Margin="10,0,30,0"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Text="停止位:" />
                <ComboBox Width="100"
                          ItemsSource="{Binding RTUConnectOptions.StopBitOptions}"
                          SelectedItem="{Binding ConnectParams.StopBit}" />
            </StackPanel>
            <StackPanel Grid.Row="4"
                        Margin="0,10"
                        Orientation="Horizontal">
                <TextBlock Margin="10,0,30,0"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Text="校验位:" />
                <ComboBox Width="100"
                          ItemsSource="{Binding RTUConnectOptions.ParityBitOptions}"
                          SelectedItem="{Binding ConnectParams.ParityBit}" />
            </StackPanel>
            <StackPanel Grid.Row="5"
                        Margin="0,10"
                        Orientation="Horizontal">
                <TextBlock Margin="10,0"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Text="超时时间:" />
                <TextBox Width="100" Text="{Binding ConnectParams.TimeOut}" />
            </StackPanel>
            <StackPanel Grid.Row="6"
                        Margin="0,10"
                        Orientation="Horizontal">
                <TextBlock Margin="10,0"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Text="重连次数:" />
                <TextBox Width="100" Text="{Binding ConnectParams.RetryCount}" />
            </StackPanel>
            <DockPanel Grid.Row="7" LastChildFill="False">
                <Button Width="60"
                        Margin="10"
                        Command="{Binding DrawerControl}"
                        CommandParameter="取消"
                        Content="取消"
                        DockPanel.Dock="Left" />
                <Button Width="60"
                        Margin="0,10"
                        Command="{Binding DrawerControl}"
                        CommandParameter="确定"
                        Content="确认"
                        DockPanel.Dock="Right" />
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
