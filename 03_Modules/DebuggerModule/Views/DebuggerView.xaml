<UserControl x:Class="_03_Modules.DebuggerModule.Views.DebuggerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:_03_Modules.DebuggerModule.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             d:DesignHeight="636.66"
             d:DesignWidth="1170"
             mc:Ignorable="d">
    <md:DrawerHost IsRightDrawerOpen="{Binding IsRightDrawerOpen}">
        <md:DrawerHost.RightDrawerContent>
            <ContentControl Width="250" Content="{Binding RightDrawerContent}" />
        </md:DrawerHost.RightDrawerContent>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="0.43*" />
                </Grid.RowDefinitions>
                <!--  数据面板部分  -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Border Grid.RowSpan="2"
                                Margin="10,0,10,10"
                                Background="#94B7EB"
                                CornerRadius="15">
                            <Border.Effect>
                                <DropShadowEffect />
                            </Border.Effect>
                        </Border>
                        <StackPanel Grid.Row="0"
                                    Margin="20,10"
                                    Orientation="Horizontal">
                            <TextBlock Width="60"
                                       Margin="10,0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="序号" />
                            <TextBlock Width="60"
                                       Margin="10,0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="地址" />
                            <TextBlock Width="130"
                                       Margin="10,0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="名称" />
                            <TextBlock Width="100"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="数值" />
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" Margin="20,0,20,20">
                            <ItemsControl ItemsSource="{Binding PointTable}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,5"
                                                BorderBrush="AliceBlue"
                                                BorderThickness="0,2,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Width="60"
                                                           Margin="10,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Index}" />
                                                <TextBlock Width="60"
                                                           Margin="10,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Address}" />
                                                <TextBox Width="120"
                                                         Margin="10,0,20,0"
                                                         Padding="4"
                                                         VerticalAlignment="Center"
                                                         FontSize="15"
                                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                         Text="{Binding Name}" />
                                                <Button Width="60"
                                                        Content="{Binding Value}"
                                                        FontSize="15" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
                <!--  日志部分  -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Border Grid.RowSpan="2"
                            Margin="10,10,0,10"
                            Background="Black"
                            CornerRadius="15">
                        <Border.Effect>
                            <DropShadowEffect />
                        </Border.Effect>
                    </Border>
                    <Grid Grid.Row="0" Margin="20,20,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="日志记录" />
                        <Border Grid.Column="1"
                                Height="1"
                                Background="White" />
                        <Button Grid.Column="2"
                                Width="25"
                                Height="25"
                                Margin="10,0,0,0"
                                Command="{Binding CleanLogsCmd}"
                                Style="{StaticResource MaterialDesignIconButton}">
                            <md:PackIcon Kind="CloseCircleOutline" />
                        </Button>
                    </Grid>
                    <ScrollViewer Grid.Row="1" Margin="20,0,20,20">
                        <ItemsControl Foreground="White" ItemsSource="{Binding Logs}" />
                    </ScrollViewer>
                </Grid>
            </Grid>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.RowSpan="3"
                            Background="#94B7EB"
                            CornerRadius="15">
                        <Border.Effect>
                            <DropShadowEffect />
                        </Border.Effect>
                    </Border>
                    <Grid Grid.Row="0" Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="通信设置" />
                        <Border Grid.Column="1"
                                Height="1"
                                Background="White" />
                    </Grid>
                    <StackPanel Grid.Row="1"
                                Margin="10,5"
                                Orientation="Horizontal">
                        <TextBlock Margin="0,0,30,0"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   Foreground="White"
                                   Text="协议类型" />
                        <RadioButton Width="61"
                                     MinWidth="0"
                                     Command="{Binding DrawerControl}"
                                     CommandParameter="TCP"
                                     Content="TCP"
                                     FontSize="15"
                                     IsChecked="{Binding TcpButtonSelected}"
                                     Style="{StaticResource MaterialDesignTabRadioButtonBottom}" />
                        <RadioButton Width="61"
                                     MinWidth="0"
                                     Command="{Binding DrawerControl}"
                                     CommandParameter="RTU"
                                     Content="RTU"
                                     FontSize="15"
                                     IsChecked="{Binding RtuButtonSelected}"
                                     Style="{StaticResource MaterialDesignTabRadioButton}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2"
                                Margin="10,0,0,0"
                                Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="15"
                                   Foreground="White"
                                   Text="连接状态" />
                        <ToggleButton Width="50"
                                      Height="30"
                                      Margin="30,10"
                                      Command="{Binding IsConnectCmd}"
                                      IsChecked="{Binding IsConnect}"
                                      IsEnabled="{Binding CanOperate}"
                                      Style="{StaticResource MaterialDesignSwitchSecondaryToggleButton}" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.RowSpan="6"
                            Background="#94B7EB"
                            CornerRadius="15">
                        <Border.Effect>
                            <DropShadowEffect />
                        </Border.Effect>
                    </Border>
                    <Grid Grid.Row="0" Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Margin="0,0,10,0"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="请求设置" />
                        <Border Grid.Column="1"
                                Height="1"
                                Background="White" />
                    </Grid>
                    <StackPanel Grid.Row="1"
                                Margin="10"
                                Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="15"
                                   Foreground="White"
                                   Text="从站地址" />
                        <TextBox Width="125"
                                 Margin="30,0,0,0"
                                 Text="{Binding RequestParams.SlaveId}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2"
                                Margin="10,10,0,10"
                                Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="15"
                                   Foreground="White"
                                   Text="功能码" />
                        <ComboBox Width="125"
                                  Margin="45,0,0,0"
                                  DisplayMemberPath="Value"
                                  ItemsSource="{Binding FunctionCodeHelper.FunctionCodeOptions}"
                                  SelectedValue="{Binding RequestParams.FunctionCode}"
                                  SelectedValuePath="Key" />
                    </StackPanel>
                    <StackPanel Grid.Row="3"
                                Margin="10"
                                Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="15"
                                   Foreground="White"
                                   Text="起始地址" />
                        <TextBox Width="125"
                                 Margin="30,0,0,0"
                                 Text="{Binding RequestParams.StartAddress}" />
                    </StackPanel>
                    <StackPanel Grid.Row="4"
                                Margin="10"
                                Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="15"
                                   Foreground="White"
                                   Text="数量" />
                        <TextBox Width="125"
                                 Margin="60,0,0,0"
                                 Text="{Binding RequestParams.Count}" />
                    </StackPanel>
                    <Button Grid.Row="5"
                            Width="100"
                            Margin="10,10,10,20"
                            HorizontalAlignment="Right"
                            Command="{Binding GenerateTableCommand}"
                            Content="生成看板" />
                </Grid>
                <md:PackIcon Grid.Row="2"
                             Width="150"
                             Height="150"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Kind="ShieldBugOutline" />
            </Grid>
        </Grid>
    </md:DrawerHost>
</UserControl>
