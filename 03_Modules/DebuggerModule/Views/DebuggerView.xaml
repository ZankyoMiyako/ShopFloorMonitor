<UserControl x:Class="_03_Modules.DebuggerModule.Views.DebuggerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:_03_Modules.DebuggerModule.Views"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             d:DesignHeight="636.66"
             d:DesignWidth="1170">
    <md:DrawerHost IsRightDrawerOpen="{Binding IsRightDrawerOpen}">
        <md:DrawerHost.RightDrawerContent>
            <ContentControl Content="{Binding RightDrawerContent}"
                            Width="250" />
        </md:DrawerHost.RightDrawerContent>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="0.43*" />
                </Grid.RowDefinitions>
                <!--数据面板部分-->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Border Grid.RowSpan="2"
                                Margin="10,0,10,10"
                                Background="#94B7EB"
                                CornerRadius="15">
                            <Border.Effect>
                                <DropShadowEffect />
                            </Border.Effect>
                        </Border>
                        <StackPanel Grid.Row="0"
                                    Margin="20,10"
                                    Orientation="Horizontal">
                            <TextBlock Text="序号"
                                       Width="60"
                                       FontSize="20"
                                       FontWeight="SemiBold" 
                                       Margin="10,0"/>
                            <TextBlock Text="地址"
                                       Width="60"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="10,0" />
                            <TextBlock Text="名称"
                                       Width="130"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="10,0" />
                            <TextBlock Text="数值"
                                       Width="100"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding TestDatas}"
                                      Margin="20,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="0,1" BorderBrush="AliceBlue" Padding="0,5">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Index}"
                                                       Width="60"
                                                       FontSize="15"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Address}"
                                                       Width="60"
                                                       FontSize="15"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0"
                                                       FontWeight="SemiBold" />
                                            <TextBox Text="{Binding Name}"
                                                     Width="120"
                                                     Margin="10,0,20,0"
                                                     FontSize="15"
                                                     VerticalAlignment="Center"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     Padding="4" />
                                            <Button Content="{Binding Data}"
                                                    Width="60"
                                                    FontSize="15" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
                <!--日志部分-->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Border Background="Black"
                            Grid.RowSpan="2"
                            Margin="10,10,0,10"
                            CornerRadius="15">
                        <Border.Effect>
                            <DropShadowEffect />
                        </Border.Effect>
                    </Border>
                    <Grid Grid.Row="0"
                          Margin="20,20,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="日志记录"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,0,10,0" />
                        <Border Grid.Column="1"
                                Height="1"
                                Background="White" />
                        <Button Grid.Column="2"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Width="25"
                                Height="25"
                                Margin="10,0,0,0"
                                Command="{Binding CleanLogsCmd}">
                            <md:PackIcon Kind="CloseCircleOutline" />
                        </Button>
                    </Grid>
                    <ScrollViewer Grid.Row="1"
                                  Margin="20,0,20,20">
                        <ItemsControl ItemsSource="{Binding Logs}"
                                      Foreground="White" />
                    </ScrollViewer>
                </Grid>
            </Grid>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0"
                      Margin="20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Border Background="#94B7EB"
                            CornerRadius="15"
                            Grid.RowSpan="3">
                        <Border.Effect>
                            <DropShadowEffect />
                        </Border.Effect>
                    </Border>
                    <Grid Grid.Row="0"
                          Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="通信设置"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Grid.Column="0"
                                   Margin="0,0,10,0" />
                        <Border Grid.Column="1"
                                Height="1"
                                Background="White" />
                    </Grid>
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="10,5">
                        <TextBlock Text="协议类型"
                                   FontSize="15"
                                   Foreground="White"
                                   Margin="0,0,30,0"
                                   VerticalAlignment="Center" />
                        <RadioButton Style="{StaticResource MaterialDesignTabRadioButtonBottom}"
                                     Content="TCP"
                                     IsChecked="{Binding TcpButtonSelected}"
                                     MinWidth="0"
                                     Width="61"
                                     FontSize="15"
                                     Command="{Binding DrawerControl}"
                                     CommandParameter="TCP" />
                        <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}"
                                     Content="RTU"
                                     IsChecked="{Binding RtuButtonSelected}"
                                     MinWidth="0"
                                     Width="61"
                                     FontSize="15"
                                     Command="{Binding DrawerControl}"
                                     CommandParameter="RTU" />
                    </StackPanel>
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="10,0,0,0">
                        <TextBlock Text="连接状态"
                                   Foreground="White"
                                   FontSize="15"
                                   VerticalAlignment="Center" />
                        <ToggleButton Margin="30,10"
                                      Width="50"
                                      Height="30"
                                      Style="{StaticResource MaterialDesignSwitchSecondaryToggleButton}"
                                      IsChecked="{Binding IsConnect}"
                                      Command="{Binding IsConnectCmd}"
                                      IsEnabled="{Binding CanOperate}" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1"
                      Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Border Background="#94B7EB"
                            CornerRadius="15"
                            Grid.RowSpan="6">
                        <Border.Effect>
                            <DropShadowEffect />
                        </Border.Effect>
                    </Border>
                    <Grid Grid.Row="0"
                          Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="请求设置"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,0,10,0" />
                        <Border Grid.Column="1"
                                Height="1"
                                Background="White" />
                    </Grid>
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="10">
                        <TextBlock Text="从站地址"
                                   FontSize="15"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBox Margin="30,0,0,0"
                                 Width="125"
                                 Text="{Binding RequestParams.SlaveId}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="10,10,0,10">
                        <TextBlock Text="功能码"
                                   FontSize="15"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                        <ComboBox Margin="45,0,0,0"
                                  Width="125"
                                  ItemsSource="{Binding FunctionCodeHelper.FunctionCodeOptions}"
                                  SelectedValue="{Binding RequestParams.FunctionCode}"
                                  DisplayMemberPath="Value"
                                  SelectedValuePath="Key" />
                    </StackPanel>
                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                Margin="10">
                        <TextBlock Text="起始地址"
                                   FontSize="15"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBox Margin="30,0,0,0"
                                 Width="125"
                                 Text="{Binding RequestParams.StartAddress}" />
                    </StackPanel>
                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                Margin="10">
                        <TextBlock Text="数量"
                                   FontSize="15"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBox Margin="60,0,0,0"
                                 Width="125"
                                 Text="{Binding RequestParams.Count}" />
                    </StackPanel>
                    <Button Grid.Row="5"
                            Width="100"
                            Content="生成看板"
                            HorizontalAlignment="Right"
                            Margin="10,10,10,20" />
                </Grid>
                <md:PackIcon Grid.Row="2"
                             Width="150"
                             Height="150"
                             Kind="ShieldBugOutline"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center" />
            </Grid>
        </Grid>
    </md:DrawerHost>
</UserControl>
