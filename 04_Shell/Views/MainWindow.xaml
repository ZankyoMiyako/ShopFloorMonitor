<Window x:Class="_04_Shell.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:_04_Shell"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="720"
        Width="1280">
    <WindowChrome.WindowChrome>
        <WindowChrome UseAeroCaptionButtons="False"
                      CaptionHeight="5" 
                      CornerRadius="15"/>
    </WindowChrome.WindowChrome>
    <Grid Background="AliceBlue">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Border Grid.ColumnSpan="2"
                    Background="White"
                    CornerRadius="15" />
            <md:ColorZone Grid.Column="0"
                          Margin="10,5"
                          Mode="PrimaryDark"
                          CornerRadius="25"
                          VerticalAlignment="Stretch">
                <ListBox ItemsSource="{Binding MenuBars}"
                         HorizontalAlignment="Center"
                         Foreground="White"
                         ItemContainerStyle="{StaticResource MenuBarStyle}"
                         Margin="0,30">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,15"
                                        Background="Transparent">
                                <StackPanel.ToolTip>
                                    <ToolTip Content="{Binding MenuName}"
                                             Placement="Right"
                                             HorizontalOffset="25"
                                             VerticalOffset="-5"
                                             Style="{StaticResource MenuBarTooltipStyle}"
                                             Foreground="White" />
                                </StackPanel.ToolTip>
                                <md:PackIcon Kind="{Binding Icon}"
                                             Width="30"
                                             Height="30">
                                </md:PackIcon>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </md:ColorZone>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0"
                           LastChildFill="False"
                           Margin="0,5">
                    <TextBlock Text="ShopFloor&#x000A;Monitor"
                               Foreground="Indigo"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Margin="5,0"
                               DockPanel.Dock="Left" />
                    <Button DockPanel.Dock="Right"
                            Margin="3,0"
                            x:Name="CloseBtn"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <md:PackIcon Kind="WindowClose"/>
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Margin="3,0"
                            x:Name="MaxBtn"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <md:PackIcon Kind="WindowMaximize"/>
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Margin="3,0"
                            x:Name="MinBtn"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <md:PackIcon Kind="WindowMinimize" />
                    </Button>
                </DockPanel>
                <ContentControl Grid.Row="1">
                    <TextBlock Text="导航页面" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</Window>
