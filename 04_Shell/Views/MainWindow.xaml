<Window x:Class="_04_Shell.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:_04_Shell"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="720"
        Width="1280">
    <WindowChrome.WindowChrome>
        <WindowChrome UseAeroCaptionButtons="False"
                      CaptionHeight="5" />
    </WindowChrome.WindowChrome>
    <Grid Background="#34409b">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Border Grid.ColumnSpan="2"
                    Background="White"
                    CornerRadius="25" />
            <md:ColorZone Grid.Column="0"
                          Margin="10,5"
                          Mode="PrimaryDark"
                          CornerRadius="25"
                          VerticalAlignment="Stretch">
                <ListBox ItemsSource="{Binding MenuBars}"
                         HorizontalAlignment="Center"
                         Foreground="White"
                         ItemContainerStyle="{StaticResource MenuBarStyle}"
                         Margin="0,30">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,15"
                                  Background="Transparent"
                                  Width="50"
                                  Height="50">
                                <Grid.ToolTip>
                                    <ToolTip Content="{Binding MenuName}"
                                             Placement="Right"
                                             HorizontalOffset="25"
                                             VerticalOffset="-5"
                                             Style="{StaticResource MenuBarTooltipStyle}"
                                             Foreground="White" />
                                </Grid.ToolTip>
                                <md:PackIcon Kind="{Binding Icon}"
                                             Width="30"
                                             Height="30"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                </md:PackIcon>
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseLeftButtonUp">
                                        <i:InvokeCommandAction Command="{Binding DataContext.NavigateCommand,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=ItemsControl}}"
                                                               CommandParameter="{Binding }" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </md:ColorZone>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0"
                           LastChildFill="False"
                           Margin="0,5">
                    <TextBlock Text="ShopFloor&#x000A;Monitor"
                               Foreground="Indigo"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Margin="5,0"
                               DockPanel.Dock="Left" />
                    <Button DockPanel.Dock="Right"
                            Margin="3,0"
                            x:Name="CloseBtn"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <md:PackIcon Kind="WindowClose" />
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Margin="3,0"
                            x:Name="MaxBtn"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <md:PackIcon Kind="WindowMaximize" />
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Margin="3,0"
                            x:Name="MinBtn"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <md:PackIcon Kind="WindowMinimize" />
                    </Button>
                </DockPanel>
                <ContentControl Grid.Row="1"
                                prism:RegionManager.RegionName="MainWindowRegion" />
            </Grid>
        </Grid>
    </Grid>
</Window>
